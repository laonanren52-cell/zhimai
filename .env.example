VITE_AI_PROVIDER=mock
VITE_API_BASE_URL=

API_PORT=3001
AI_PROVIDER=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=45000

# Optional web search. If omitted, /api/search returns an explicit unconfigured warning.
WEB_SEARCH_ENABLED=true
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPAPI_KEY=

# Optional OCR provider flag. OCR is not implemented in this local proxy yet, but the health endpoint reports this state.
OCR_PROVIDER=
OCR_API_KEY=
